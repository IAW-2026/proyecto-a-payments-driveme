# pnpm supply-chain hardening
# Quarantine window: 7 days (10080 minutes) — packages published less than 7 days ago are blocked
minimumReleaseAge=10080m
blockExoticSubdeps=true
# "audit" warns on trust downgrade but allows install; use "no-downgrade" to block once all deps are verified
trust-policy=audit
strict-dep-builds=true
save-exact=true
