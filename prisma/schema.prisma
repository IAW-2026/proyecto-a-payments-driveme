generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Rol {
  RIDER
  DRIVER
  ADMIN
}

enum TipoMetodoPago {
  TARJETA
  EFECTIVO
}

enum MarcaTarjeta {
  VISA
  MASTERCARD
  AMEX
  OTHER
}

enum EstadoTransaccion {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
  CANCELED
}

enum EstadoReembolso {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum EstadoFondoSemanal {
  ABIERTO    // current week, still accumulating
  CERRADO    // week ended, awaiting payout request
  LIQUIDADO  // payout executed
}

enum EstadoLiquidacion {
  PENDIENTE
  PROCESADA
  FALLIDA
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Usuario {
  id            String   @id          
  rol           Rol      @default(RIDER)
  fechaCreacion DateTime @default(now())

  @@map("usuarios")
}


model MetodoPago {
  id              String         @id @default(uuid())
  idUsuario       String         
  tipo            TipoMetodoPago
  token           String?        
  gatewayProvider String?
  activo          Boolean        @default(true)
  fechaCreacion   DateTime       @default(now())

  tarjeta         Tarjeta?
  transacciones   Transaccion[]

  @@map("metodos_pago")
}


model Tarjeta {
  id                   String       @id @default(uuid())
  metodoPagoId         String       @unique
  metodoPago           MetodoPago   @relation(fields: [metodoPagoId], references: [id])
  numeroEnmascarado    String
  marca                MarcaTarjeta
  numero               Int
  anioVencimiento      Int
  mesVencimiento       Int
  nombreTitular        String
  direccionFacturacion String?
  fechaAgregado        DateTime     @default(now())

  @@map("tarjetas")
}


model FondoSemanal {
  id                 String             @id @default(uuid())
  idConductor        String             // Clerk sub (driver)
  periodoInicio      DateTime           // Monday 00:00 UTC
  periodoFin         DateTime           // Sunday 23:59 UTC
  montoBruto         Decimal            @default(0) @db.Decimal(12, 2)
  montoRetenido      Decimal            @default(0) @db.Decimal(12, 2)
  estado             EstadoFondoSemanal @default(ABIERTO)
  fechaCreacion      DateTime           @default(now())
  fechaActualizacion DateTime           @updatedAt

  transacciones      Transaccion[]
  reembolsos         Reembolso[]
  liquidacion        Liquidacion?

  // One fund per driver per week
  @@unique([idConductor, periodoInicio])
  @@map("fondos_semanales")
}


model Transaccion {
  id                   String            @id @default(uuid())
  idViaje              String            
  idPasajero           String            
  idConductor          String            
  metodoPagoId         String?
  metodoPago           MetodoPago?       @relation(fields: [metodoPagoId], references: [id])
  fondoSemanalId       String?
  fondoSemanal         FondoSemanal?     @relation(fields: [fondoSemanalId], references: [id])
  monto                Decimal           @db.Decimal(12, 2)
  moneda               String            @default("ARS")
  estado               EstadoTransaccion @default(PENDING)
  gatewayProvider      String?
  gatewayTransactionId String?
  detalleGateway       Json?             
  fechaCreacion        DateTime          @default(now())
  fechaActualizacion   DateTime          @updatedAt

  reembolsos           Reembolso[]

  @@map("transacciones")
}


model Reembolso {
  id                 String          @id @default(uuid())
  transaccionId      String
  transaccion        Transaccion     @relation(fields: [transaccionId], references: [id])
  fondoSemanalId     String          
  fondoSemanal       FondoSemanal    @relation(fields: [fondoSemanalId], references: [id])
  monto              Decimal         @db.Decimal(12, 2)
  estado             EstadoReembolso @default(PENDING)
  razon              String
  gatewayRefundId    String?
  fechaSolicitud     DateTime        @default(now())
  fechaActualizacion DateTime        @updatedAt

  @@map("reembolsos")
}


model Liquidacion {
  id                 String            @id @default(uuid())
  fondoSemanalId     String            @unique
  fondoSemanal       FondoSemanal      @relation(fields: [fondoSemanalId], references: [id])
  idConductor        String            
  montoPagado        Decimal           @db.Decimal(12, 2)
  estado             EstadoLiquidacion @default(PENDIENTE)
  fechaProgramada    DateTime
  fechaEjecutada     DateTime?
  detalle            Json?             
  fechaCreacion      DateTime          @default(now())
  fechaActualizacion DateTime          @updatedAt

  @@map("liquidaciones")
}
