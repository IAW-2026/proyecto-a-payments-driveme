generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"

}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Rol {
  RIDER
  DRIVER
  ADMIN
}

enum MetodoPago {
  EFECTIVO
  MERCADO_PAGO
}

enum EstadoTransaccion {
  PENDIENTE
  CONFIRMADO
  CANCELADO
}

enum EstadoLiquidacionTx {
  PENDIENTE
  LIQUIDADO
}

enum EstadoLiquidacion {
  PENDIENTE
  PROCESADA
  FALLIDA
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Usuario {
  id            String   @id
  rol           Rol      @default(RIDER)
  fechaCreacion DateTime @default(now())

  @@map("usuarios")
}

model Transaccion {
  id                   String              @id @default(uuid())
  idViaje              String              @unique
  idPasajero           String
  idConductor          String
  metodoPago           MetodoPago
  monto                Decimal             @db.Decimal(12, 2)
  estado               EstadoTransaccion   @default(PENDIENTE)
  estadoLiquidacion    EstadoLiquidacionTx @default(PENDIENTE)
  gatewayProvider      String?
  gatewayTransactionId String?
  detalleGateway       Json?
  fechaCreacion        DateTime            @default(now())
  fechaActualizacion   DateTime            @updatedAt

  @@map("transaccion")
}

model Billetera {
  id                 String   @id @default(uuid())
  idConductor        String   @unique
  montoPendiente     Decimal  @default(0) @db.Decimal(12, 2)
  montoLiquidado     Decimal  @default(0) @db.Decimal(12, 2)
  fechaCreacion      DateTime @default(now())
  fechaActualizacion DateTime @updatedAt

  @@map("billetera")
}

model Liquidacion {
  id                 String            @id @default(uuid())
  idConductor        String
  montoPagado        Decimal           @db.Decimal(12, 2)
  estado             EstadoLiquidacion @default(PENDIENTE)
  fechaProgramada    DateTime
  fechaEjecutada     DateTime?
  detalle            Json?
  fechaCreacion      DateTime          @default(now())
  fechaActualizacion DateTime          @updatedAt

  @@map("liquidacion")
}

model BancoCentral {
  id                       String   @id @default("main")
  fondosEmpresa            Decimal  @default(0) @db.Decimal(12, 2)
  fondosADebitar           Decimal  @default(0) @db.Decimal(12, 2)
  fondosDebitadosHistorico Decimal  @default(0) @db.Decimal(12, 2)
  fechaActualizacion       DateTime @updatedAt

  @@map("banco_central")
}
