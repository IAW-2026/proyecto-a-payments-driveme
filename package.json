{
  "name": "payments-driveme",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "cross-env NODE_OPTIONS=--use-system-ca next dev",
    "type": "module",
    "build": "cross-env NODE_OPTIONS=--use-system-ca next build",
    "start": "cross-env NODE_OPTIONS=--use-system-ca next start",
    "lint": "next lint",
    "db:generate": "cross-env NODE_OPTIONS=--use-system-ca prisma generate",
    "db:push": "cross-env NODE_OPTIONS=--use-system-ca prisma db push",
    "db:migrate": "cross-env NODE_OPTIONS=--use-system-ca prisma migrate dev",
    "db:studio": "cross-env NODE_OPTIONS=--use-system-ca prisma studio"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.3.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "next": "^16.2.6",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.6",
    "@types/node": "^25.6.2",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.3",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-config-next": "^16.2.6",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.1.6",
    "typescript": "^6.0.3"
  }
}
